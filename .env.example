# Supabase (required for admin auth and data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: override password-reset redirect during local development
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback?next=/admin/reset-password

# Resend (credit application notification emails)
RESEND_API_KEY=re_xxxxxxxx
# Defaults to swiss.motorsportss@gmail.com if unset
CREDIT_APPLICATION_NOTIFICATION_EMAIL=swiss.motorsportss@gmail.com
# Verified sender in Resend (use onboarding@resend.dev only for testing)
CREDIT_APPLICATION_FROM_EMAIL=Swiss Motorsports <onboarding@resend.dev>
